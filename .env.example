# OpenRouter API key.
# Required for chat unless you enter a key in OpenConvo Settings.
# Get yours at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Hosted free mode limit when OPENROUTER_API_KEY is configured on the server
# and a visitor has not added their own key in Settings.
OPENCONVO_HOSTED_FREE_DAILY_LIMIT=20

# Tavily Search API key.
# Optional. Improves web research quality; keyless fallback search is built in.
# Get yours at https://tavily.com
TAVILY_API_KEY=

# Optional self-hosted metasearch endpoint, for example https://search.example.com
# When set, OpenConvo tries Tavily, then SearxNG, then keyless DuckDuckGo fallback.
SEARXNG_URL=

# Hosted search limit for visitors without their own Tavily key.
OPENCONVO_HOSTED_SEARCH_DAILY_LIMIT=5

# Public GitHub repo URL shown on the landing page after you publish the project.
NEXT_PUBLIC_GITHUB_URL=https://github.com/fayzkk889/openconvo

# Public site URL used for Open Graph images and social previews.
NEXT_PUBLIC_SITE_URL=https://openconvo.vercel.app
